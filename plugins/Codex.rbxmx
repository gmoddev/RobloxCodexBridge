			write = function()
				-- Codex handles this in a custom way
				return true
			end,
		},
		InitialSize = {
			read = function(instance: MeshPart)
				return true, instance.MeshSize
			end,
			write = function()
				-- Codex handles this in a custom way
				return true
			end,
		},
	},
