				<Item class="Folder" referent="RBX8A9E8B5F02354CBD893A115D4382A638">
					<Properties>
						<BinaryString name="AttributesSerialize">AQAAAA0AAABDb2RleFVuaXF1ZUlEAgwAAAB1T3Jad2U2QXVPclo=</BinaryString>
						<SecurityCapabilities name="Capabilities">0</SecurityCapabilities>
						<bool name="DefinesCapabilities">false</bool>
						<string name="Name">evaera_promise@4.0.0</string>
