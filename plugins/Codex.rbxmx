							<string name="ScriptGuid">{568b829f-e362-4d36-b2dd-cf2a9df8651c}</string>
							<BinaryString name="AttributesSerialize">AQAAAA0AAABDb2RleFVuaXF1ZUlEAgwAAAB0b29qMjRYUHRvb2o=</BinaryString>
							<SecurityCapabilities name="Capabilities">0</SecurityCapabilities>
