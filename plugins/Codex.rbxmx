					</Item>
					<Item class="ModuleScript" referent="RBXFF2D1E74B9044FE1BEA95B4F6B8B6F7A">
						<Properties>
							<Content name="LinkedSource"><null></null></Content>
							<ProtectedString name="Source"><![CDATA[return function(props: { [any]: any }, strip: { string }): { [any]: any }
	props = table.clone(props)

	for _, prop in strip do
		props[prop] = nil
	end

	return props
end
]]></ProtectedString>
