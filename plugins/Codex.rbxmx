					<string name="Name">describeChanges</string>
					<int64 name="SourceAssetId">-1</int64>
					<SharedString name="Tags">yuZpQdnvvUBOTYh1jqZ2cA==</SharedString>
				</Properties>
			</Item>
			<Item class="ModuleScript" referent="RBX01BFAB56C5484C6181FE4CD84C8B8E87">
				<Properties>
					<Content name="LinkedSource"><null></null></Content>
					<ProtectedString name="Source"><![CDATA[local function getClassName(instance: Instance): string
	-- Return the appropriate source property name based on instance class
	if instance:IsA("Script") or instance:IsA("LocalScript") or instance:IsA("ModuleScript") then
		return "Source"
	elseif instance:IsA("StringValue") then
		return "Value"
	else
		-- Default fallback
		return "Source"
	end
end

return getClassName
]]></ProtectedString>
					<string name="ScriptGuid">{73ec452e-f9d6-45cd-8de6-794322db0dc8}</string>
